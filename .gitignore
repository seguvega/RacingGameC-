## Unreal Engine project (.uproject)

# Visual Studio / MSBuild user-specific files
.vs/
*.VC.db
*.VC.opendb
*.suo
*.opensdf
*.sdf
*.user
*.userosscache
*.userprefs

# VS Code (keep common team-shared JSON files if you want them committed)
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json

# JetBrains Rider / IntelliJ
.idea/
*.sln.iml

# Avoid broad filetype ignores (e.g., *.dll / *.lib / *.exe).
# Unreal projects commonly vendor third-party binaries under Source/ThirdParty,
# and directory-based ignores below already cover generated build outputs.

# Debug symbols / compiler intermediates
*.pdb
*.idb
*.ilk
*.ipch
*.dSYM/

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.code-workspace

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/
Plugins/**/Binaries/

# Project Build/ can contain required packaging resources (icons, platform configs).
# Keep it tracked by default. If you want to ignore a *specific* generated subfolder,
# add a targeted rule rather than ignoring Build/ wholesale.

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/
Plugins/**/Saved/

# Logs / crash reports (often end up outside Saved/ in edge cases)
*.log
crashinfo-

# Compiled source files for the engine to use
Intermediate/
Plugins/**/Intermediate/

# Cache files for the editor to use
DerivedDataCache/
Plugins/**/DerivedDataCache/

# OS junk
Thumbs.db
Desktop.ini
.DS_Store
